# Variables de entorno para pruebas E2E (LOCAL únicamente)
# Copia este archivo a .env.test (gitignored) o expórtalas en tu shell.
#
# NUNCA usar credenciales de producción aquí.

# Usuario de prueba local (debe existir en la BD local finanzas_personales)
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# URLs locales (valores por defecto si se omiten)
E2E_BASE_URL=http://localhost:3000
E2E_API_URL=http://localhost:3001
