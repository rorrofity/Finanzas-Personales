# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finanzas_personales
DB_USER=your_username
DB_PASSWORD=your_password

# Server Configuration
PORT=5000
JWT_SECRET=your_jwt_secret_key

# Google OAuth Configuration
# Obtén estos valores desde Google Cloud Console
# Ver documentación en GOOGLE_OAUTH_SETUP.md
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# External Services
BANK_API_URL=https://example.bank.com/api
BANK_API_KEY=your_bank_api_key

# N8N Configuration
# URL del webhook de N8N para sincronización de emails
# Producción: http://localhost:5678/webhook/sync-bank-emails (mismo servidor)
# Desarrollo local: Usa túnel SSH o URL de N8N en producción
N8N_WEBHOOK_URL=http://localhost:5678/webhook/sync-bank-emails

# Environment
NODE_ENV=development

# Sincronización programada (Epic 13)
# Zona horaria del scheduler (node-cron). Formato cron: "MIN HORA * * *"
TZ=America/Santiago
SYNC_CRON_TIMES=0 13 * * *,0 22 * * *
# El scheduler solo corre en NODE_ENV=production salvo que actives esto:
ENABLE_SCHEDULER=false

# Web Push / VAPID (Epic 13)
# Generar con: node -e "console.log(require('web-push').generateVAPIDKeys())"
# NUNCA commitear las claves reales; usar un par distinto por ambiente.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@example.com
